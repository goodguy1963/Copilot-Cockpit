{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Package and install Copilot Cockpit (Insiders)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"package:vsix",
				";",
				"npm",
				"run",
				"install:vsix:insiders"
			],
			"isBackground": false
		},
		{
			"label": "Build MCP server bundle",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"esbuild-server",
				"--",
				"--sourcemap"
			],
			"isBackground": false,
			"group": "build"
		}
	]
}